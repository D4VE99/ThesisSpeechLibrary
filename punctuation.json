{
  "standard": "W3C SSML 1.1",
  "language": "pt-PT",
  "punctuation_rules": [
    { "symbol": ".", "type": "terminative", "break": "strong", "pitch": "-20%", "contour": "(80%, -10%) (100%, -25%)" },
    { "symbol": ",", "type": "continuative", "break": "weak", "pitch": "+10%", "contour": "(80%, +5%) (100%, +12%)" },
    { "symbol": ";", "type": "pause", "break": "medium", "pitch": "medium", "contour": "(90%, -5%)" },
    { "symbol": ":", "type": "explicative", "break": "medium", "pitch": "low", "rate": "slow" },
    { "symbol": "!", "type": "exclamative", "break": "strong", "pitch": "high", "volume": "+3dB", "range": "high" },
    { "symbol": "?", "type": "interrogative", "break": "strong", "pitch": "high", "contour": "(0%, +0%) (60%, +15%) (100%, +35%)" },
    { "symbol": "...", "type": "hesitation", "break": "x-strong", "rate": "x-slow", "pitch": "-5%" },
    { "symbol": "-", "type": "hyphen", "break": "x-weak", "rate": "fast" },
    { "symbol": "–", "type": "en-dash", "break": "medium", "pitch": "medium" },
    { "symbol": "—", "type": "em-dash", "break": "medium", "pitch": "medium" },
    { "symbol": "(", "type": "parenthesis-open", "break": "weak", "pitch": "low", "volume": "soft", "rate": "fast" },
    { "symbol": ")", "type": "parenthesis-close", "break": "weak", "pitch": "reset", "volume": "reset", "rate": "reset" },
    { "symbol": "\"", "type": "quote", "break": "none", "emphasis": "moderate" },
    { "symbol": "«", "type": "guillemet-open", "break": "none", "emphasis": "moderate" },
    { "symbol": "»", "type": "guillemet-close", "break": "none", "emphasis": "reset" },
    { "symbol": "“", "type": "curly-quote-open", "break": "none", "emphasis": "moderate" },
    { "symbol": "”", "type": "curly-quote-close", "break": "none", "emphasis": "reset" }
  ]
}
